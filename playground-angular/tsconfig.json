{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "lib": ["DOM", "ES2022"],
    "skipLibCheck": true,
    "strict": false,
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts"]
}
