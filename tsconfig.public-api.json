{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "markstream-vue": ["./dist/index.d.ts"],
      "markstream-vue/utils": ["./dist/index.d.ts"],
      "markstream-vue/utils/katex-threshold": ["./dist/index.d.ts"],
      "markstream-vue/utils/performance-monitor": ["./dist/index.d.ts"],
      "markstream-vue/utils/safeRaf": ["./dist/index.d.ts"],
      "markstream-vue/workers/katexWorkerClient": ["./dist/index.d.ts"],
      "markstream-vue/workers/mermaidWorkerClient": ["./dist/index.d.ts"],
      "markstream-vue/workers/katexCdnWorker": ["./dist/index.d.ts"],
      "markstream-vue/workers/mermaidCdnWorker": ["./dist/index.d.ts"],
      "markstream-core": ["./packages/markstream-core/dist/index.d.ts"],
      "stream-markdown-parser": ["./packages/markdown-parser/dist/index.d.ts"]
    },
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    // Keep true for now because this fixture validates consumer-facing usage,
    // while full declaration integrity is covered by build:dts and snapshot.
    "skipLibCheck": true
  },
  "include": ["test/public-api/public-api-usage.ts", "test/public-api/PublicApiComponents.vue"]
}
