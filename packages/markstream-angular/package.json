{
  "name": "markstream-angular",
  "type": "module",
  "version": "0.0.4",
  "description": "Angular standalone streaming Markdown renderer for AI chat, SSE/WebSocket output, long documents, Mermaid, KaTeX, Monaco, D2, and Infographic.",
  "author": "Simon He",
  "license": "MIT",
  "homepage": "https://markstream.simonhe.me/frameworks/angular",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Simon-He95/markstream-vue.git",
    "directory": "packages/markstream-angular"
  },
  "bugs": {
    "url": "https://github.com/Simon-He95/markstream-vue/issues"
  },
  "keywords": [
    "angular",
    "angular-standalone",
    "markdown",
    "markdown-renderer",
    "angular-markdown",
    "streaming-markdown",
    "ai-chat",
    "llm",
    "sse",
    "websocket",
    "mermaid",
    "katex",
    "monaco-editor",
    "large-documents",
    "custom-components",
    "markstream-angular",
    "markstream"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./index.css": "./dist/index.css",
    "./workers/katexRenderer.worker": "./dist/workers/katexRenderer.worker.js",
    "./workers/mermaidParser.worker": "./dist/workers/mermaidParser.worker.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --dir ../markstream-core build && vite build --mode npm",
    "dev": "vite dev",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run check:workspace-deps-published",
    "check:core-published": "node ../../scripts/check-core-published.mjs --package-json package.json --core-package-json ../markstream-core/package.json",
    "check:workspace-deps-published": "node ../../scripts/check-workspace-deps-published.mjs --package-json package.json",
    "release": "pnpm run check:workspace-deps-published && bumpp --commit --no-tag --no-push && pnpm publish --access public && node ../../scripts/tag-package.mjs --package-json package.json --push"
  },
  "peerDependencies": {
    "@angular/common": ">=20",
    "@angular/core": ">=20",
    "@antv/infographic": "^0.2.3",
    "@terrastruct/d2": ">=0.1.33",
    "katex": ">=0.16.22",
    "mermaid": ">=11",
    "stream-monaco": ">=0.0.45"
  },
  "peerDependenciesMeta": {
    "@antv/infographic": {
      "optional": true
    },
    "@terrastruct/d2": {
      "optional": true
    },
    "katex": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    },
    "stream-monaco": {
      "optional": true
    }
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "markstream-core": "workspace:*",
    "stream-markdown-parser": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "rollup": "^3.30.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vite-plugin-dts": "^4.5.4"
  }
}
